---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props as { frontmatter: any };
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="mx-auto max-w-2xl px-6 py-12">
    <p class="text-xs uppercase tracking-[0.3em] text-accent text-center">{frontmatter.category}</p>
    <h1 class="font-heading text-3xl text-primary text-center mt-3 mb-6">{frontmatter.title}</h1>
    <div class="text-ink leading-loose"><slot /></div>
  </article>
</BaseLayout>
---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
const entries = (await getCollection('articles')).filter(e => !e.data.hideFromHome);
---
<BaseLayout title="UK IHT Desk" description="UK 继承税与遗产规划（IHT / probate / 跨境遗产 / nil rate band 实操）">
  <section class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="font-heading text-4xl text-primary leading-tight">UK IHT Desk</h1>
    <p class="text-lg text-muted mt-4">UK 继承税与遗产规划（IHT / probate / 跨境遗产 / nil rate band 实操）</p>
    <div class="mt-12">{entries.map((entry) => <ArticleCard entry={entry} />)}</div>
  </section>
</BaseLayout>